# Database
DATABASE_URL=                  # asyncpg DSN: postgresql://user:password@host/dbname

# Auth
SECRET_KEY=                    # random 32-byte hex string
ACCESS_TOKEN_EXPIRE_HOURS=8

# Admin seed (used by a one-time setup script, not the app itself)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# File uploads (local storage)
UPLOAD_DIR=./uploads           # directory where uploaded images are stored

# Umami (optional — only needed for the analytics proxy endpoint)
UMAMI_BASE_URL=
UMAMI_API_KEY=
UMAMI_WEBSITE_ID=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
